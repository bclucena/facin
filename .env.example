# ─── Banco de dados ──────────────────────────────────────────────────────────
# PostgreSQL local (ex: Docker) ou Neon/Supabase em produção
DATABASE_URL="postgresql://postgres:password@localhost:5432/facin_dev"

# ─── Clerk — Autenticação ────────────────────────────────────────────────────
# Crie sua conta em https://clerk.com e crie dois aplicativos:
#   1. facin-web   → para apps/web
#   2. facin-master → para apps/master
#
# Cada app deve ter seu próprio .env.local com as chaves correspondentes.
# Abaixo as variáveis necessárias nos dois apps:

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# URLs de redirecionamento do Clerk (padrão)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
