{
  "name": "facin",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "postinstall": "packages/db/node_modules/.bin/prisma generate --schema=packages/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@11.9.0"
}