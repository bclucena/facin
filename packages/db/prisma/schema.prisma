generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output        = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ───────────────────────────────────────────────────────────
// Toda entidade de negócio tem tenantId (Row-Level Isolation).
// tenantId corresponde ao organizationId do Clerk.

model Tenant {
  id        String   @id @default(cuid())
  clerkOrgId String  @unique
  name      String
  cnpj      String   @unique
  slug      String   @unique
  plan      Plan     @default(FREE)
  active    Boolean  @default(true)
  primaryColor String @default("#0F5132")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]

  @@map("tenants")
}

model User {
  id         String   @id @default(cuid())
  clerkUserId String  @unique
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  role       UserRole @default(OPERATOR)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@map("users")
}

// ─── Cadastros ───────────────────────────────────────────────────────────────

model Cliente {
  id            String   @id @default(cuid())
  tenantId      String
  nome          String
  documento     String
  telefone      String?
  whatsapp      String?
  email         String?
  cep           String?
  endereco      String?
  bairro        String?
  cidade        String?
  uf            String?  @db.Char(2)
  limiteCredito Decimal  @default(0) @db.Decimal(12, 2)
  tabelaPreco   String?
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accountsReceivable AccountsReceivable[]
  salesOrders        SalesOrder[]

  @@index([tenantId])
  @@map("clientes")
}

model Fornecedor {
  id            String   @id @default(cuid())
  tenantId      String
  nome          String
  cnpj          String
  ie            String?
  tipoAtividade String?
  telefone      String?
  whatsapp      String?
  email         String?
  cep           String?
  endereco      String?
  prazoEntrega  Int      @default(0)
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accountsPayable AccountsPayable[]
  purchaseQuotes  PurchaseQuote[]
  purchaseOrders  PurchaseOrder[]

  @@index([tenantId])
  @@map("fornecedores")
}

model Produto {
  id            String   @id @default(cuid())
  tenantId      String
  codigo        String
  codigoBarras  String?
  descricao     String
  unidade       String   @default("UN")
  tipo          String?
  grupo         String?
  fabricante    String?
  estoqueMinimo Decimal  @default(0) @db.Decimal(12, 3)
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stockBalances       StockBalance[]
  stockMovements      StockMovement[]
  inventoryCountItems InventoryCountItem[]
  purchaseQuoteItems  PurchaseQuoteItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  salesOrderItems     SalesOrderItem[]

  @@unique([tenantId, codigo])
  @@index([tenantId])
  @@map("produtos")
}

model Deposito {
  id        String   @id @default(cuid())
  tenantId  String
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  inventoryCounts InventoryCount[]

  @@index([tenantId])
  @@map("depositos")
}

// ─── Estoque ─────────────────────────────────────────────────────────────────

model StockBalance {
  id           String      @id @default(cuid())
  tenantId     String
  productId    String
  warehouseId  String
  accountType  AccountType @default(ESTOQUE)
  quantity     Decimal     @default(0) @db.Decimal(12, 3)
  qtyCommitted Decimal     @default(0) @db.Decimal(12, 3)
  expiryDate   DateTime?
  updatedAt    DateTime    @updatedAt

  product   Produto  @relation(fields: [productId], references: [id])
  warehouse Deposito @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, productId, warehouseId, accountType])
  @@index([tenantId])
  @@map("stock_balances")
}

model StockMovement {
  id               String       @id @default(cuid())
  tenantId         String
  productId        String
  warehouseId      String
  accountType      AccountType  @default(ESTOQUE)
  movementType     MovementType
  quantity         Decimal      @db.Decimal(12, 3)
  lot              String?
  manufacturingDate DateTime?
  expiryDate       DateTime?
  notes            String?
  userId           String?
  createdAt        DateTime     @default(now())

  product   Produto  @relation(fields: [productId], references: [id])
  warehouse Deposito @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

model InventoryCount {
  id          String      @id @default(cuid())
  tenantId    String
  warehouseId String
  accountType AccountType @default(ESTOQUE)
  status      String      @default("OPEN")
  userId      String?
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  warehouse Deposito             @relation(fields: [warehouseId], references: [id])
  items     InventoryCountItem[]

  @@index([tenantId])
  @@map("inventory_counts")
}

model InventoryCountItem {
  id               String  @id @default(cuid())
  inventoryCountId String
  productId        String
  systemQty        Decimal @db.Decimal(12, 3)
  countedQty       Decimal @default(0) @db.Decimal(12, 3)

  inventoryCount InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  product        Produto        @relation(fields: [productId], references: [id])

  @@map("inventory_count_items")
}

// ─── Compras ─────────────────────────────────────────────────────────────────

model PurchaseQuote {
  id           String      @id @default(cuid())
  tenantId     String
  supplierId   String
  supplierName String
  number       String
  issueDate    DateTime
  expectedDate DateTime?
  paymentTerms String?
  status       QuoteStatus @default(DRAFT)
  totalAmount  Decimal     @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())

  supplier Fornecedor         @relation(fields: [supplierId], references: [id])
  items    PurchaseQuoteItem[]
  orders   PurchaseOrder[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("purchase_quotes")
}

model PurchaseQuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  productId String
  quantity  Decimal @db.Decimal(12, 3)
  unitCost  Decimal @db.Decimal(12, 4)
  totalCost Decimal @db.Decimal(12, 2)

  quote   PurchaseQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Produto       @relation(fields: [productId], references: [id])

  @@map("purchase_quote_items")
}

model PurchaseOrder {
  id           String      @id @default(cuid())
  tenantId     String
  supplierId   String
  supplierName String
  quoteId      String?
  number       String
  issueDate    DateTime
  expectedDate DateTime?
  paymentTerms String?
  status       OrderStatus @default(PENDING)
  totalAmount  Decimal     @db.Decimal(12, 2)
  nfNumber     String?
  nfDate       DateTime?
  nfAmount     Decimal?    @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())

  supplier Fornecedor        @relation(fields: [supplierId], references: [id])
  quote    PurchaseQuote?    @relation(fields: [quoteId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  quantity    Decimal @db.Decimal(12, 3)
  unitCost    Decimal @db.Decimal(12, 4)
  totalCost   Decimal @db.Decimal(12, 2)
  receivedQty Decimal @default(0) @db.Decimal(12, 3)

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Produto       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// ─── Financeiro ──────────────────────────────────────────────────────────────

model AccountsPayable {
  id           String       @id @default(cuid())
  tenantId     String
  supplierId   String?
  supplierName String
  description  String
  amount       Decimal      @db.Decimal(12, 2)
  dueDate      DateTime
  paidAt       DateTime?
  paidAmount   Decimal?     @db.Decimal(12, 2)
  paymentType  PaymentType?
  status       BillStatus   @default(PENDING)
  notes        String?
  createdAt    DateTime     @default(now())

  supplier Fornecedor? @relation(fields: [supplierId], references: [id])

  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@map("accounts_payable")
}

model AccountsReceivable {
  id             String       @id @default(cuid())
  tenantId       String
  clientId       String?
  clientName     String
  description    String
  amount         Decimal      @db.Decimal(12, 2)
  dueDate        DateTime
  receivedAt     DateTime?
  receivedAmount Decimal?     @db.Decimal(12, 2)
  paymentType    PaymentType?
  status         BillStatus   @default(PENDING)
  notes          String?
  createdAt      DateTime     @default(now())

  client Cliente? @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@map("accounts_receivable")
}

model CashFlow {
  id            String       @id @default(cuid())
  tenantId      String
  description   String
  amount        Decimal      @db.Decimal(12, 2)
  type          CashFlowType
  accountCode   String?
  referenceDate DateTime
  createdAt     DateTime     @default(now())

  @@index([tenantId])
  @@index([tenantId, referenceDate])
  @@map("cash_flow")
}

// ─── Vendas ──────────────────────────────────────────────────────────────────

model SalesOrder {
  id            String           @id @default(cuid())
  tenantId      String
  clientId      String?
  clientName    String
  number        String
  issueDate     DateTime
  deliveryDate  DateTime?
  status        SalesOrderStatus @default(DRAFT)
  subtotal      Decimal          @db.Decimal(12, 2)
  discountTotal Decimal          @default(0) @db.Decimal(12, 2)
  total         Decimal          @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  client Cliente?        @relation(fields: [clientId], references: [id])
  items  SalesOrderItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  productUnit String  @default("UN")
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 4)
  discountPct Decimal @default(0) @db.Decimal(5, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Produto    @relation(fields: [productId], references: [id])

  @@map("sales_order_items")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum AccountType {
  ESTOQUE_NF
  ESTOQUE
  ESTOQUE_FISICO
}

enum MovementType {
  ENTRADA
  SAIDA
}

enum PaymentType {
  BOLETO
  PIX
  CHEQUE
  PROMISSORIA
  TED
  DINHEIRO
}

enum BillStatus {
  PENDING
  PAID
}

enum CashFlowType {
  CREDIT
  DEBIT
}

enum QuoteStatus {
  DRAFT
  SENT
  CONVERTED
}

enum OrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  INVOICED
  CANCELLED
}
